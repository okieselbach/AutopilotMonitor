{
  "name": "autopilot-monitor-mcp",
  "version": "1.5.1",
  "description": "MCP server for Autopilot-Monitor — enables AI agents to query enrollment sessions, device properties, events and vulnerabilities",
  "type": "module",
  "bin": {
    "autopilot-monitor-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "docker:build": "docker build -f Dockerfile -t autopilotmonitor-mcp:local ../../../",
    "docker:run": "docker run --rm -p 8080:8080 -e AUTOPILOT_API_URL=https://autopilotmonitor-api-eu.azurewebsites.net autopilotmonitor-mcp:local",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "fuse.js": "^7.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "sharp": "^0.35.0",
    "fast-uri": "^3.1.4",
    "hono": "^4.12.27",
    "@hono/node-server": "^2.0.5"
  }
}
